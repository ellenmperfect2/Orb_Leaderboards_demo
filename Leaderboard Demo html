function rankUsageMap(usageMap: Map<string, { displayName: string; consumed: number }>) {
  return Array.from(usageMap.entries())
    .map(([id, { displayName, consumed }]) => ({ id, displayName, creditsUsed: consumed }))
    .sort((a, b) => b.creditsUsed - a.creditsUsed)
    .map((u, i) => ({ ...u, rank: i + 1 }));
