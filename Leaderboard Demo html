### API call pattern (TypeScript)

Use this exact pagination pattern for both calls:

\`\`\`typescript
let cursor: string | null = null;
do {
  const params = new URLSearchParams({
    subscription_id: subscriptionId,
    license_type_id: licenseTypeId,
    start_date: startDate,
    end_date: endDate,
    group_by: "license",
    limit: "100",
  });
  if (cursor) params.set("cursor", cursor);

  const res = await fetch(\`https://api.withorb.com/v1/licenses/usage?\${params}\`, {
    headers: {
      Authorization: \`Bearer \${process.env.ORB_API_KEY}\`,
      Accept: "application/json",
    },
    cache: "no-store",
  });

  if (!res.ok) {
    const body = await res.text().catch(() => "");
    throw new Error(\`Orb API \${res.status}: \${body}\`);
  }

  const data = await res.json();
  all.push(...data.data);
  cursor = data.pagination_metadata?.next_cursor ?? null;
} while (cursor);
\`\`\`

